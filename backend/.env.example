# ── Qdrant ─────────────────────────────────────────────────────────────────────
# Required for Qdrant Cloud. Get yours from https://cloud.qdrant.io/
QDRANT_API_KEY=your-qdrant-api-key-here

# Required: Qdrant cluster URL. Get yours from https://cloud.qdrant.io/
QDRANT_URL=https://your-cluster.gcp.cloud.qdrant.io:6333

# Optional: use a local on-disk Qdrant instance instead of cloud (dev only)
# QDRANT_PATH=./qdrant_local

# ── Ollama model names ─────────────────────────────────────────────────────────
# Ensure each model is pulled before starting the server:
#   ollama pull bge-m3
#   ollama pull llama3.3:70b
#   ollama pull deepseek-r1:7b
#   ollama pull translategemma:4b

# Embedding model (must produce 1024-dim vectors to match the Qdrant collection)
EMBED_MODEL=bge-m3

# LLM for RAG Q&A and ingest extraction
RAG_LLM_MODEL=llama3.3:70b
LLM_MODEL=llama3.3:70b

# LLM for rhetorical role classification
RHET_MODEL=deepseek-r1:7b

# LLM for translation
TRANSLATION_MODEL=translategemma:4b
